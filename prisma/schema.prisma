// ============================================================================
// aPoint MVP — Prisma Schema
// Based on: apoint_mvp_spec.md v1.2
// Database: PostgreSQL 16 + PostGIS
// ============================================================================

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
  binaryTargets   = ["native", "linux-musl-openssl-3.0.x", "linux-musl"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [postgis, pgcrypto]
}

// ============================================================================
// USERS
// ============================================================================

model User {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email        String   @unique @db.VarChar(255)
  phone        String?  @db.VarChar(20)
  firstName    String   @map("first_name") @db.VarChar(100)
  lastName     String   @map("last_name") @db.VarChar(100)
  avatarUrl    String?  @map("avatar_url")
  authProvider String   @default("email") @map("auth_provider") @db.VarChar(20)
  passwordHash String?  @map("password_hash")
  isVerified   Boolean  @default(false) @map("is_verified")
  userType     UserType @default(USER) @map("user_type")
  locale       String   @default("hr") @db.VarChar(5)
  timezone     String   @default("Europe/Zagreb") @db.VarChar(50)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  // Relations
  ownedBusinesses Business[]
  workers         Worker[]
  bookings        Booking[]
  reviews         Review[]
  favorites       Favorite[]
  notifications   Notification[]
  serviceRecords  ServiceRecord[] @relation("CustomerRecords")
  refreshTokens   RefreshToken[]
  deviceTokens    DeviceToken[]

  @@map("users")
}

enum UserType {
  USER     @map("user")
  PROVIDER @map("provider")

  @@map("user_type_enum")
}

// ============================================================================
// REFRESH TOKENS (for JWT rotation)
// ============================================================================

model RefreshToken {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  token     String   @unique @db.VarChar(500)
  expiresAt DateTime @map("expires_at") @db.Timestamptz()
  isRevoked Boolean  @default(false) @map("is_revoked")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

// ============================================================================
// DEVICE TOKENS (for push notifications)
// ============================================================================

model DeviceToken {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  token     String   @unique @db.VarChar(500)
  platform  String   @db.VarChar(10) // 'ios', 'android', 'web'
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("device_tokens")
}

// ============================================================================
// CATEGORIES
// ============================================================================

model Category {
  id        String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  parentId  String? @map("parent_id") @db.Uuid
  name      String  @db.VarChar(255)
  nameHr    String  @map("name_hr") @db.VarChar(255)
  slug      String  @unique @db.VarChar(255)
  icon      String? @db.VarChar(50)
  sortOrder Int     @default(0) @map("sort_order")
  isActive  Boolean @default(true) @map("is_active")

  parent   Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children Category[] @relation("CategoryTree")

  businesses Business[]
  services   Service[]

  @@map("categories")
}

// ============================================================================
// BUSINESSES
// ============================================================================

model Business {
  id                String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ownerId           String  @map("owner_id") @db.Uuid
  name              String  @db.VarChar(255)
  slug              String  @unique @db.VarChar(255)
  description       String?
  categoryId        String? @map("category_id") @db.Uuid
  logoUrl           String? @map("logo_url")
  coverPhotoUrl     String? @map("cover_photo_url")
  website           String? @db.VarChar(255)
  instagram         String? @db.VarChar(255)
  facebook          String? @db.VarChar(255)
  isActive          Boolean @default(true) @map("is_active")
  bookingMode       String  @default("instant") @map("booking_mode") @db.VarChar(20)
  cancellationHours Int     @default(24) @map("cancellation_hours")
  depositType       String  @default("none") @map("deposit_type") @db.VarChar(10)
  depositAmount     Decimal @default(0) @map("deposit_amount") @db.Decimal(10, 2)
  stripeAccountId   String? @map("stripe_account_id") @db.VarChar(255)
  whatsappNumber    String? @map("whatsapp_number") @db.VarChar(20)
  whatsappConnected Boolean @default(false) @map("whatsapp_connected")
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt         DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  // Relations
  owner          User             @relation(fields: [ownerId], references: [id])
  category       Category?        @relation(fields: [categoryId], references: [id])
  locations      Location[]
  services       Service[]
  workers        Worker[]
  bookings       Booking[]
  reviews        Review[]         @relation("BusinessReviews")
  favorites      Favorite[]
  serviceRecords ServiceRecord[]
  whatsappConvos WhatsappConversation[]

  @@map("businesses")
}

// ============================================================================
// LOCATIONS
// ============================================================================

model Location {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  businessId   String   @map("business_id") @db.Uuid
  name         String   @db.VarChar(255)
  addressLine1 String   @map("address_line1") @db.VarChar(255)
  addressLine2 String?  @map("address_line2") @db.VarChar(255)
  city         String   @db.VarChar(100)
  postalCode   String?  @map("postal_code") @db.VarChar(20)
  country      String   @default("HR") @db.VarChar(2)
  latitude     Decimal  @db.Decimal(10, 8)
  longitude    Decimal  @db.Decimal(11, 8)
  phone        String?  @db.VarChar(20)
  isPrimary    Boolean  @default(false) @map("is_primary")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  business        Business         @relation(fields: [businessId], references: [id], onDelete: Cascade)
  workingHours    WorkingHours[]
  blockedSlots    BlockedSlot[]
  bookings        Booking[]
  workerLocations WorkerLocation[]

  @@map("locations")
}

// ============================================================================
// WORKING HOURS
// ============================================================================

model WorkingHours {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  locationId String   @map("location_id") @db.Uuid
  dayOfWeek  Int      @map("day_of_week") @db.SmallInt // 0=Monday
  openTime   String   @map("open_time") @db.VarChar(5) // "09:00"
  closeTime  String   @map("close_time") @db.VarChar(5) // "17:00"
  breakStart String?  @map("break_start") @db.VarChar(5)
  breakEnd   String?  @map("break_end") @db.VarChar(5)
  isClosed   Boolean  @default(false) @map("is_closed")

  location Location @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@unique([locationId, dayOfWeek])
  @@map("working_hours")
}

// ============================================================================
// BLOCKED SLOTS (breaks, holidays, personal time)
// ============================================================================

model BlockedSlot {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  locationId  String?  @map("location_id") @db.Uuid
  workerId    String?  @map("worker_id") @db.Uuid
  startTime   DateTime @map("start_time") @db.Timestamptz()
  endTime     DateTime @map("end_time") @db.Timestamptz()
  reason      String?  @db.VarChar(255)
  isRecurring Boolean  @default(false) @map("is_recurring")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz()

  location Location? @relation(fields: [locationId], references: [id], onDelete: Cascade)
  worker   Worker?   @relation(fields: [workerId], references: [id], onDelete: Cascade)

  @@map("blocked_slots")
}

// ============================================================================
// SERVICES
// ============================================================================

model Service {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  businessId      String   @map("business_id") @db.Uuid
  name            String   @db.VarChar(255)
  description     String?
  durationMinutes Int      @map("duration_minutes")
  price           Decimal  @db.Decimal(10, 2)
  currency        String   @default("EUR") @db.VarChar(3)
  categoryId      String?  @map("category_id") @db.Uuid
  isActive        Boolean  @default(true) @map("is_active")
  requiresDeposit Boolean  @default(false) @map("requires_deposit")
  sortOrder       Int      @default(0) @map("sort_order")
  locationType    String   @default("at_business") @map("location_type") @db.VarChar(20)
  travelSurcharge Decimal  @default(0) @map("travel_surcharge") @db.Decimal(10, 2)
  travelRadiusKm  Int      @default(0) @map("travel_radius_km")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt       DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  business        Business          @relation(fields: [businessId], references: [id], onDelete: Cascade)
  category        Category?         @relation(fields: [categoryId], references: [id])
  workerServices  WorkerService[]
  bookingServices BookingService[]
  whatsappConvos  WhatsappConversation[]

  @@map("services")
}

// ============================================================================
// WORKERS (Team Members)
// ============================================================================

model Worker {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  businessId   String   @map("business_id") @db.Uuid
  businessRole String   @default("worker") @map("business_role") @db.VarChar(20)
  displayName  String?  @map("display_name") @db.VarChar(255)
  avatarUrl    String?  @map("avatar_url")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  user            User             @relation(fields: [userId], references: [id])
  business        Business         @relation(fields: [businessId], references: [id], onDelete: Cascade)
  workerLocations WorkerLocation[]
  workerServices  WorkerService[]
  bookings        Booking[]
  blockedSlots    BlockedSlot[]

  @@unique([userId, businessId])
  @@map("workers")
}

model WorkerLocation {
  workerId   String @map("worker_id") @db.Uuid
  locationId String @map("location_id") @db.Uuid

  worker   Worker   @relation(fields: [workerId], references: [id], onDelete: Cascade)
  location Location @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@id([workerId, locationId])
  @@map("worker_locations")
}

model WorkerService {
  workerId  String @map("worker_id") @db.Uuid
  serviceId String @map("service_id") @db.Uuid

  worker  Worker  @relation(fields: [workerId], references: [id], onDelete: Cascade)
  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@id([workerId, serviceId])
  @@map("worker_services")
}

// ============================================================================
// BOOKINGS
// ============================================================================

model Booking {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  bookingNumber   String   @unique @map("booking_number") @db.VarChar(20)
  userId          String?  @map("user_id") @db.Uuid
  businessId      String   @map("business_id") @db.Uuid
  locationId      String?  @map("location_id") @db.Uuid
  workerId        String   @map("worker_id") @db.Uuid

  startTime       DateTime @map("start_time") @db.Timestamptz()
  endTime         DateTime @map("end_time") @db.Timestamptz()
  durationMinutes Int      @map("duration_minutes")

  status          BookingStatus @default(PENDING)

  // Guest info
  guestName       String?  @map("guest_name") @db.VarChar(255)
  guestEmail      String?  @map("guest_email") @db.VarChar(255)
  guestPhone      String?  @map("guest_phone") @db.VarChar(20)

  // Mobile service address
  customerAddress    String?  @map("customer_address")
  customerAddressLat Decimal? @map("customer_address_lat") @db.Decimal(10, 8)
  customerAddressLng Decimal? @map("customer_address_lng") @db.Decimal(11, 8)

  // Payment
  totalPrice     Decimal @map("total_price") @db.Decimal(10, 2)
  depositAmount  Decimal @default(0) @map("deposit_amount") @db.Decimal(10, 2)
  paymentStatus  PaymentStatus @default(NONE) @map("payment_status")

  // Metadata
  source              String?  @default("app") @db.VarChar(20)
  notes               String?
  cancellationReason  String?  @map("cancellation_reason")
  cancelledAt         DateTime? @map("cancelled_at") @db.Timestamptz()

  // Reschedule tracking
  rescheduledFromId      String?  @map("rescheduled_from_id") @db.Uuid
  rescheduleProposedBy   String?  @map("reschedule_proposed_by") @db.VarChar(10)
  rescheduleProposedAt   DateTime? @map("reschedule_proposed_at") @db.Timestamptz()

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  // Relations
  user            User?           @relation(fields: [userId], references: [id])
  business        Business        @relation(fields: [businessId], references: [id])
  location        Location?       @relation(fields: [locationId], references: [id])
  worker          Worker          @relation(fields: [workerId], references: [id])
  rescheduledFrom Booking?        @relation("RescheduleChain", fields: [rescheduledFromId], references: [id])
  rescheduledTo   Booking[]       @relation("RescheduleChain")
  bookingServices BookingService[]
  payments        Payment[]
  review          Review?
  serviceRecord   ServiceRecord?

  @@index([userId])
  @@index([businessId])
  @@index([workerId, startTime, endTime])
  @@index([status])
  @@map("bookings")
}

enum BookingStatus {
  PENDING              @map("pending")
  CONFIRMED            @map("confirmed")
  IN_PROGRESS          @map("in_progress")
  COMPLETED            @map("completed")
  CANCELLED_BY_USER    @map("cancelled_by_user")
  CANCELLED_BY_PROVIDER @map("cancelled_by_provider")
  NO_SHOW              @map("no_show")
  REJECTED             @map("rejected")

  @@map("booking_status_enum")
}

enum PaymentStatus {
  NONE               @map("none")
  DEPOSIT_PAID       @map("deposit_paid")
  FULLY_PAID         @map("fully_paid")
  REFUNDED           @map("refunded")
  PARTIALLY_REFUNDED @map("partially_refunded")

  @@map("payment_status_enum")
}

// ============================================================================
// BOOKING SERVICES (multi-service per booking)
// ============================================================================

model BookingService {
  id              String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  bookingId       String  @map("booking_id") @db.Uuid
  serviceId       String  @map("service_id") @db.Uuid
  serviceName     String  @map("service_name") @db.VarChar(255)
  durationMinutes Int     @map("duration_minutes")
  price           Decimal @db.Decimal(10, 2)
  sortOrder       Int     @default(0) @map("sort_order") @db.SmallInt

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  service Service @relation(fields: [serviceId], references: [id])

  @@index([bookingId])
  @@map("booking_services")
}

// ============================================================================
// SERVICE RECORDS (service history)
// ============================================================================

model ServiceRecord {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  bookingId          String   @unique @map("booking_id") @db.Uuid
  businessId         String   @map("business_id") @db.Uuid
  customerId         String?  @map("customer_id") @db.Uuid
  notes              String?
  productsUsed       Json?    @map("products_used")
  visibleToCustomer  Boolean  @default(true) @map("visible_to_customer")
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt          DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  booking  Booking              @relation(fields: [bookingId], references: [id])
  business Business             @relation(fields: [businessId], references: [id])
  customer User?                @relation("CustomerRecords", fields: [customerId], references: [id])
  photos   ServiceRecordPhoto[]

  @@index([businessId, customerId])
  @@index([customerId])
  @@map("service_records")
}

model ServiceRecordPhoto {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  recordId  String   @map("record_id") @db.Uuid
  photoUrl  String   @map("photo_url")
  caption   String?
  takenAt   DateTime @default(now()) @map("taken_at") @db.Timestamptz()
  sortOrder Int      @default(0) @map("sort_order") @db.SmallInt

  record ServiceRecord @relation(fields: [recordId], references: [id], onDelete: Cascade)

  @@map("service_record_photos")
}

// ============================================================================
// PAYMENTS
// ============================================================================

model Payment {
  id                     String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  bookingId              String   @map("booking_id") @db.Uuid
  stripePaymentIntentId  String?  @unique @map("stripe_payment_intent_id") @db.VarChar(255)
  amount                 Decimal  @db.Decimal(10, 2)
  currency               String   @default("EUR") @db.VarChar(3)
  type                   String   @db.VarChar(20)
  status                 String   @default("pending") @db.VarChar(20)
  platformFee            Decimal  @default(0) @map("platform_fee") @db.Decimal(10, 2)
  providerPayout         Decimal  @default(0) @map("provider_payout") @db.Decimal(10, 2)
  stripeTransferId       String?  @map("stripe_transfer_id") @db.VarChar(255)
  refundAmount           Decimal? @map("refund_amount") @db.Decimal(10, 2)
  refundReason           String?  @map("refund_reason")
  createdAt              DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt              DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  booking Booking @relation(fields: [bookingId], references: [id])

  @@map("payments")
}

// ============================================================================
// REVIEWS
// ============================================================================

model Review {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  bookingId    String   @unique @map("booking_id") @db.Uuid
  reviewerId   String   @map("reviewer_id") @db.Uuid
  revieweeType String   @map("reviewee_type") @db.VarChar(10)
  revieweeId   String   @map("reviewee_id") @db.Uuid
  rating       Int      @db.SmallInt
  comment      String?
  reply        String?
  replyAt      DateTime? @map("reply_at") @db.Timestamptz()
  isPublished  Boolean  @default(true) @map("is_published")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  booking  Booking  @relation(fields: [bookingId], references: [id])
  reviewer User     @relation(fields: [reviewerId], references: [id])
  business Business? @relation("BusinessReviews", fields: [revieweeId], references: [id])

  @@index([revieweeType, revieweeId])
  @@map("reviews")
}

// ============================================================================
// NOTIFICATIONS
// ============================================================================

model Notification {
  id      String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId  String   @map("user_id") @db.Uuid
  type    String   @db.VarChar(50)
  title   String   @db.VarChar(255)
  body    String
  data    Json?
  channel String   @db.VarChar(10)
  isRead  Boolean  @default(false) @map("is_read")
  sentAt  DateTime @default(now()) @map("sent_at") @db.Timestamptz()
  readAt  DateTime? @map("read_at") @db.Timestamptz()

  user User @relation(fields: [userId], references: [id])

  @@index([userId, isRead, sentAt(sort: Desc)])
  @@map("notifications")
}

// ============================================================================
// FAVORITES
// ============================================================================

model Favorite {
  userId     String   @map("user_id") @db.Uuid
  businessId String   @map("business_id") @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz()

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@id([userId, businessId])
  @@map("favorites")
}

// ============================================================================
// WHATSAPP CONVERSATIONS
// ============================================================================

model WhatsappConversation {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  businessId        String   @map("business_id") @db.Uuid
  waPhoneNumber     String   @map("wa_phone_number") @db.VarChar(20)
  conversationState String   @default("initial") @map("conversation_state") @db.VarChar(20)
  selectedServiceId String?  @map("selected_service_id") @db.Uuid
  selectedSlot      DateTime? @map("selected_slot") @db.Timestamptz()
  lastMessageAt     DateTime @default(now()) @map("last_message_at") @db.Timestamptz()
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt         DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  business        Business @relation(fields: [businessId], references: [id])
  selectedService Service? @relation(fields: [selectedServiceId], references: [id])

  @@index([businessId, waPhoneNumber])
  @@map("whatsapp_conversations")
}
